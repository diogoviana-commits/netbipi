# ============================================================
# NetBIPI - Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores
# ============================================================

# ------------------------------------------------------------
# SERVIDOR
# ------------------------------------------------------------
PORT=3001
NODE_ENV=development

# ------------------------------------------------------------
# BANCO DE DADOS (PostgreSQL)
# ------------------------------------------------------------
# Mantenha a senha alinhada com POSTGRES_PASSWORD abaixo.
DATABASE_URL=postgresql://netbipi:CHANGE_ME_POSTGRES_PASSWORD@localhost:5432/netbipi

# Para Docker Compose interno:
# DATABASE_URL=postgresql://netbipi:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/netbipi

# ------------------------------------------------------------
# JWT / AUTENTICAÇÃO
# ------------------------------------------------------------
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=24h

# ------------------------------------------------------------
# CORS
# ------------------------------------------------------------
FRONTEND_URL=http://localhost:5173

# Para produção com Docker:
# FRONTEND_URL=http://localhost

# ------------------------------------------------------------
# INTEGRAÇÕES
# Mantenha MOCK_INTEGRATIONS=false para operar com integrações reais.
# Ative true apenas para demonstração local sem Zabbix/GLPI.
# ------------------------------------------------------------
MOCK_INTEGRATIONS=false

# ------------------------------------------------------------
# ZABBIX
# URL interna (dentro do Docker): http://zabbix-web:8080/api_jsonrpc.php
# URL externa (acesso local):     http://localhost:8080/api_jsonrpc.php
# ------------------------------------------------------------
ZABBIX_DB_NAME=zabbix
ZABBIX_DB_USER=zabbix
ZABBIX_DB_PASSWORD=CHANGE_ME_ZABBIX_DB_PASSWORD
ZABBIX_DB_ROOT_PASSWORD=CHANGE_ME_ZABBIX_DB_ROOT_PASSWORD
ZABBIX_URL=http://localhost:8080/api_jsonrpc.php
ZABBIX_USER=Admin
ZABBIX_PASSWORD=CHANGE_ME_ZABBIX_PASSWORD
ZABBIX_WEBHOOK_SECRET=CHANGE_ME_ZABBIX_WEBHOOK_SECRET

# ------------------------------------------------------------
# GLPI
# URL interna (dentro do Docker): http://glpi/apirest.php
# URL externa (acesso local):     http://localhost:8081/apirest.php
#
# Para obter os tokens, execute após o GLPI estar rodando:
#   bash glpi/setup/configure_glpi.sh
# ------------------------------------------------------------
GLPI_DB_NAME=glpi
GLPI_DB_USER=glpi
GLPI_DB_PASSWORD=CHANGE_ME_GLPI_DB_PASSWORD
GLPI_DB_ROOT_PASSWORD=CHANGE_ME_GLPI_DB_ROOT_PASSWORD
GLPI_URL=http://localhost:8081/apirest.php
GLPI_APP_TOKEN=CHANGE_ME_GLPI_APP_TOKEN
GLPI_USER_TOKEN=CHANGE_ME_GLPI_USER_TOKEN

# ------------------------------------------------------------
# FRONTEND (Vite — prefixo VITE_ obrigatório)
# ------------------------------------------------------------
VITE_API_URL=http://localhost:3001/api
VITE_APP_NAME=NetBIPI
VITE_APP_VERSION=1.0.0

# ------------------------------------------------------------
# DOCKER COMPOSE
# ------------------------------------------------------------
POSTGRES_DB=netbipi
POSTGRES_USER=netbipi
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Perfis disponíveis: monitoring, itsm, full
# Exemplo: docker-compose --profile full up -d
