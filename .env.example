# ============================================================
# NetBIPI - Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores
# ============================================================

# ------------------------------------------------------------
# SERVIDOR
# ------------------------------------------------------------
PORT=3001
NODE_ENV=development

# ------------------------------------------------------------
# BANCO DE DADOS (PostgreSQL)
# ------------------------------------------------------------
DATABASE_URL=postgresql://netbipi:netbipi123@localhost:5432/netbipi

# Para Docker Compose interno:
# DATABASE_URL=postgresql://netbipi:netbipi123@postgres:5432/netbipi

# ------------------------------------------------------------
# JWT / AUTENTICAÇÃO
# ------------------------------------------------------------
JWT_SECRET=netbipi-super-secret-key-mude-em-producao-minimo-32-chars
JWT_EXPIRES_IN=24h

# ------------------------------------------------------------
# CORS
# ------------------------------------------------------------
FRONTEND_URL=http://localhost:5173

# Para produção com Docker:
# FRONTEND_URL=http://localhost

# ------------------------------------------------------------
# INTEGRAÇÕES
# Mantenha MOCK_INTEGRATIONS=false para operar com integrações reais.
# Ative true apenas para demonstração local sem Zabbix/GLPI.
# ------------------------------------------------------------
MOCK_INTEGRATIONS=false

# ------------------------------------------------------------
# ZABBIX
# URL interna (dentro do Docker): http://zabbix-web:8080/api_jsonrpc.php
# URL externa (acesso local):     http://localhost:8080/api_jsonrpc.php
# ------------------------------------------------------------
ZABBIX_URL=http://localhost:8080/api_jsonrpc.php
ZABBIX_USER=Admin
ZABBIX_PASSWORD=zabbix
ZABBIX_WEBHOOK_SECRET=netbipi-webhook-secret-2024

# ------------------------------------------------------------
# GLPI
# URL interna (dentro do Docker): http://glpi/apirest.php
# URL externa (acesso local):     http://localhost:8081/apirest.php
#
# Para obter os tokens, execute após o GLPI estar rodando:
#   bash glpi/setup/configure_glpi.sh
# ------------------------------------------------------------
GLPI_URL=http://localhost:8081/apirest.php
GLPI_APP_TOKEN=netbipi-glpi-app-token
GLPI_USER_TOKEN=netbipi-glpi-user-token

# ------------------------------------------------------------
# FRONTEND (Vite — prefixo VITE_ obrigatório)
# ------------------------------------------------------------
VITE_API_URL=http://localhost:3001/api
VITE_APP_NAME=NetBIPI
VITE_APP_VERSION=1.0.0

# ------------------------------------------------------------
# DOCKER COMPOSE
# ------------------------------------------------------------
POSTGRES_DB=netbipi
POSTGRES_USER=netbipi
POSTGRES_PASSWORD=netbipi123

# Perfis disponíveis: monitoring, itsm, full
# Exemplo: docker-compose --profile full up -d
